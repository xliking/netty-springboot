<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="xlike.top.nettydemo.mapper.ChatGroupMapper">

    <select id="findGroupsByUserId" resultType="xlike.top.nettydemo.entity.ChatGroup">
        SELECT
            g.*
        FROM
            chat_group g
                JOIN
            group_member gm ON g.id = gm.group_id
        WHERE
            gm.user_id = #{userId}
    </select>

</mapper>